# Database
# Local dev: run `docker-compose up -d` first
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guestlist
# Same as DATABASE_URL for local dev; in production use a non-pooled/direct connection
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/guestlist

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret
# NEXTAUTH_URL is the canonical base URL for this app.
# It controls email verification/reset links, Stripe redirect URLs, and internal API calls.
# In production, set this to your public domain, e.g. https://evently.swiss
# In local dev, set this to the IP/hostname reachable from users' devices, e.g. http://192.168.1.x:3000
# Do NOT leave this as localhost in any environment where email links must be clicked externally.
NEXTAUTH_URL=http://localhost:3000

# Email (Resend preferred)
# Get API key from https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Email (SMTP fallback)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_FROM=

# Super Admin Seed (run: npx prisma db seed)
SUPER_ADMIN_EMAIL=you@evently.swiss
SUPER_ADMIN_PASSWORD=change-me-before-seeding
