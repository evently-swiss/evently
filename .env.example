# Database
# Local dev: run `docker-compose up -d` first
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guestlist
# Same as DATABASE_URL for local dev; in production use a non-pooled/direct connection
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/guestlist

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret
NEXTAUTH_URL=http://localhost:3000

# App
# Base URL used for links in emails (no trailing slash)
APP_URL=http://localhost:3000

# Email (Resend preferred)
# Get API key from https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Email (SMTP fallback)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_FROM=
