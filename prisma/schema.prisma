generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROMOTER
  ENTRY_STAFF
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LinkType {
  GENERAL
  PROMOTER
  PERSONAL
}

enum FieldMode {
  HIDDEN
  OPTIONAL
  REQUIRED
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  WAITLISTED
}

enum EventSource {
  INTERNAL
  SCRAPED
}

enum ScrapedSyncStatus {
  NEW
  RECONCILED
  DUPLICATE
  FAILED
}

enum LoungeStatus {
  PENDING
  CONFIRMED
  ARRIVED
  CANCELLED
}

enum PromoterVenueRole {
  RESIDENT
  GUEST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  verificationToken String? @unique
  passwordHash  String
  role          Role      @default(PROMOTER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  eventsCreated      Event[]      @relation("CreatedEvents")
  assignedEvents     Event[]      @relation("EventPromoters")
  assignedSignupLinks SignupLink[] @relation("AssignedPromoters")
  guests             Guest[]      @relation("PromoterGuests")
  checkIns           CheckIn[]
  doorEvents         Event[]      @relation("DoorStaffEvents")
  passwordResetTokens PasswordResetToken[]
  promoterVenues        PromoterVenue[]
  operatorSubscription  OperatorSubscription?
  featuredEventPayments FeaturedEvent[]       @relation("FeaturedEventPayments")
}

model Event {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  venueId       String?
  source        EventSource @default(INTERNAL)
  scrapedEventId String?    @unique
  scrapedEvent  ScrapedEvent? @relation(fields: [scrapedEventId], references: [externalUid], onDelete: SetNull)
  featuredEvent FeaturedEvent?
  date          DateTime
  startTime     String?     // e.g. "22:00"
  endTime       String?     // e.g. "04:00"
  venueName     String?
  address       String?
  description   String?
  djNames       String[]    @default([])
  genre         String?
  label         String?
  flyerImage    String?
  titleImage    String?
  status        EventStatus @default(DRAFT)
  capacity      Int?        // Overall max guests

  // Branding
  logoUrl       String?
  heroImageUrl  String?
  accentColor   String?     // e.g. "#FF0000"

  // Lounge layout override (optional; falls back to venue active layout)
  loungeLayoutId String?
  loungeLayout   LoungeLayout? @relation(fields: [loungeLayoutId], references: [id], onDelete: SetNull)

  createdByUserId String
  createdBy       User      @relation("CreatedEvents", fields: [createdByUserId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  venue              Venue?      @relation(fields: [venueId], references: [id], onDelete: SetNull)
  signupLinks        SignupLink[]
  guests             Guest[]
  lounges            Lounge[]
  loungeReservations LoungeReservation[]
  doorStaff          User[]      @relation("DoorStaffEvents")
  assignedPromoters  User[]      @relation("EventPromoters")
}

model ScrapedEvent {
  id          String            @id @default(cuid())
  externalUid String            @unique
  venueSlug   String
  title       String
  date        DateTime
  startTime   String?
  endTime     String?
  eventUrl    String?
  imageUrl    String?
  cost        String?
  tags        String[]          @default([])
  syncStatus  ScrapedSyncStatus @default(NEW)
  scrapedAt   DateTime          @default(now())
  checkedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  event Event?
}

model Venue {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  address        String?
  city           String?
  country        String   @default("CH")
  contactEmail   String?
  contactPhone   String?
  loungeEnabled  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  events              Event[]
  loungeReservations  LoungeReservation[]
  promoters           PromoterVenue[]
  loungeLayouts       LoungeLayout[]
}

model PromoterVenue {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueId   String
  venue     Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  role      PromoterVenueRole @default(GUEST)
  since     DateTime          @default(now())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, venueId])
  @@index([userId])
  @@index([venueId])
}

model SignupLink {
  id                   String    @id @default(cuid())
  eventId              String
  event                Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Many-to-many: Links can be assigned to multiple promoters
  assignedPromoters    User[]    @relation("AssignedPromoters")

  type                 LinkType  @default(GENERAL)
  slug                 String    @unique
  title                String?   // Internal label
  
  maxTotalGuests       Int?
  maxPlusOnesPerSignup Int       @default(3)
  singleUse            Boolean   @default(false)
  active               Boolean   @default(true)

  // Field Config
  emailMode            FieldMode @default(REQUIRED)
  phoneMode            FieldMode @default(OPTIONAL)
  allowNotes           Boolean   @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  guests               Guest[]
}

model Guest {
  id             String      @id @default(cuid())
  eventId        String
  event          Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  signupLinkId   String?
  signupLink     SignupLink? @relation(fields: [signupLinkId], references: [id], onDelete: SetNull)

  promoterId     String?
  promoter       User?       @relation("PromoterGuests", fields: [promoterId], references: [id])

  firstName      String
  lastName       String
  email          String?
  phone          String?
  plusOnesCount  Int         @default(0)
  note           String?
  rsvpStatus     RsvpStatus  @default(PENDING)
  inviteToken    String?     @unique
  invitedAt      DateTime?
  qrToken        String?     @unique

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  checkIn        CheckIn?
  lounges        Lounge[]
}

model Lounge {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  tableNumbers    String[]
  arrivalTime     String?
  minConsumation  Float?
  numberOfGuests  Int

  guestId         String?
  guest           Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
}

model LoungeReservation {
  id              String       @id @default(cuid())
  eventId         String
  event           Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venueId         String
  venue           Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  phone           String
  arrivalTime     String
  numberOfGuests  Int
  loungeNumbers   Int[]
  minConsumation  Decimal      @db.Decimal(10, 2)
  comments        String?
  status          LoungeStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}


model LoungeLayout {
  id        String       @id @default(cuid())
  venueId   String
  venue     Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String       @default("Main Floor")
  width     Int          @default(1200)
  height    Int          @default(800)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  boxes     LoungeBox[]
  events    Event[]

  @@index([venueId])
}

model LoungeBox {
  id             String        @id @default(cuid())
  layoutId       String
  layout         LoungeLayout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  label          String
  number         Int
  x              Float
  y              Float
  width          Float
  height         Float
  shape          String        @default("rect")
  color          String?
  capacity       Int?
  minConsumation Decimal?      @db.Decimal(10, 2)
  isActive       Boolean       @default(true)

  @@index([layoutId])
}
model CheckIn {
  id                String   @id @default(cuid())
  guestId           String   @unique
  guest             Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  checkedInByUserId String
  checkedInBy       User     @relation(fields: [checkedInByUserId], references: [id])

  checkedInAt       DateTime @default(now())
  checkedInCount    Int      @default(1)
  checkedOutAt      DateTime?
  checkedOutCount   Int?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model OperatorSubscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String    // e.g. "active", "trialing", "past_due", "canceled"
  currentPeriodEnd     DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model FeaturedEvent {
  id                      String    @id @default(cuid())
  eventId                 String    @unique
  event                   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  stripePaymentIntentId   String    @unique
  paidByUserId            String
  paidBy                  User      @relation("FeaturedEventPayments", fields: [paidByUserId], references: [id])
  expiresAt               DateTime
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([eventId])
  @@index([expiresAt])
}
